#include <stdio.h>

int main()
{
    char str[100]="snehitha";
    int i = 0;
    scanf("%s", str);

    while(str[i] != '\0')
    {
        if(str[i] >= 'a' && str[i] <= 'z')
        {
            str[i] = str[i] - 32;
        }
        i++;
    }

    printf("Uppercase string: %s", str);

    return 0;
}
