
#include <stdio.h>

int findMax(int *a, int n) {
    int max = *a;

    for(int i = 1; i < n; i++) {
        if(*(a + i) > max)
            max = *(a + i);
    }

    return max;
}

int main() {
    int arr[] = {3, 7, 2, 9, 5};
    int max = findMax(arr, 5);

    printf("Max = %d", max);
    return 0;
}
