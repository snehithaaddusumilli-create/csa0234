

#include <stdio.h>

int main() {
    char str1[] = "apple";
    char str2[] = "apple";
    char *p1 = str1;
    char *p2 = str2;

    while(*p1 && *p2) {
        if(*p1 != *p2) {
            printf("Not Equal");
            return 0;
        }
        p1++;
        p2++;
    }

    if(*p1 == *p2)
        printf("Equal");
    else
        printf("Not Equal");

    return 0;
}
