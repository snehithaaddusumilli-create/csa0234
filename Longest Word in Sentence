#include<stdio.h>
#include<string.h>

int main(){
    char str[200],word[50];
    int i=0,j=0,max=0;

    gets(str);

    while(str[i]!='\0'){
        if(str[i]!=' '){
            word[j++]=str[i];
        }
        else{
            if(j>max) max=j;
            j=0;
        }
        i++;
    }

    if(j>max) max=j;

    printf("Longest length = %d",max);
}
