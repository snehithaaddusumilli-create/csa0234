#include <stdio.h>

int main()
{
    char str[100]="snehitha";
    char rev[100];
    int i = 0, j = 0, len = 0;
    scanf("%s", str);

    while(str[i] != '\0')
    {
        len++;
        i++;
    }

    i = len - 1;

    while(i >= 0)
    {
        rev[j] = str[i];
        j++;
        i--;
    }

    rev[j] = '\0';

    printf("Reversed string: %s", rev);

    return 0;
}
