#include <stdio.h>
#include <string.h>

int main()
{
    char str[100];

    printf("Enter a string: ");
    scanf("%s", str);

    strupr(str);
    strlwr(str);
    strrev(str);
    printf("Uppercase string: %s", str);
    printf("Lowercase string: %s", str);
    printf("Reversed string: %s", str);
    return 0;
}
