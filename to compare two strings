#include <stdio.h>
#include <string.h>

int main()
{
    char str1[100]="snehitha"; 
    char str2[100]="bhavya";
    scanf("%s", str1);
    scanf("%s", str2);

    if(strcmp(str1, str2) == 0)
    {
        printf("Strings are equal");
    }
    else
    {
        printf("Strings are not equal");
    }

    return 0;
}
